// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model AdminUser {
  id           Int    @id @default(autoincrement())
  email        String @unique
  passwordHash String

  @@map("admin_users")
}

model AnalyticsEvent {
  id          Int      @id @default(autoincrement())
  type        String
  projectSlug String?
  createdAt   DateTime @default(now())

  @@map("analytics_events")
}

// Cuentas de visitantes (distintas de AdminUser) — para comentar en
// proyectos y auto-completar el formulario de contacto. Función construida
// pero mantenida oculta en el frontend hasta nuevo aviso (VISITOR_AUTH_ENABLED).
model VisitorUser {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  comments     Comment[]

  @@map("visitor_users")
}

model Comment {
  id          Int         @id @default(autoincrement())
  projectSlug String
  content     String
  status      String      @default("pending") // pending | approved | rejected
  createdAt   DateTime    @default(now())
  visitor     VisitorUser @relation(fields: [visitorId], references: [id])
  visitorId   Int

  @@map("comments")
  @@index([projectSlug, status])
}
